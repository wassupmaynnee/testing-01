# Keep the build context small and the image clean. The Dockerfile does
# `COPY . .` and serves the PRE-BUILT site/dist (no Node stage), so dist stays
# in — only build/runtime cruft and local venvs are excluded.

# VCS
.git
.gitignore
.gitattributes

# Node (Dockerfile serves the committed site/dist; it never runs npm)
node_modules
site/node_modules
**/node_modules

# Python virtualenvs & bytecode caches
.venv
.venv-test
**/__pycache__
*.pyc
*.pyo

# Tooling caches
.ruff_cache
.pytest_cache
.mypy_cache

# Local runtime artifacts (dirs are recreated by the app / entrypoint)
data/uploads/*
data/clips/*
data/checkpoints/*

# Misc
*.zip
*.log
.DS_Store
