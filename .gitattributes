# Normalize all text to LF in the repo. Critical for entrypoint.sh and other
# shell scripts: a CRLF shebang breaks `#!/usr/bin/env bash` inside the Linux
# container ("bad interpreter"). Keep everything LF so the image builds anywhere.
* text=auto eol=lf
*.sh text eol=lf
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
