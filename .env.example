# ----------------------------------------------------------------------------
# Clippify SaaS — environment template.
# Copy to .env and fill values. NEVER commit a real .env.
# ----------------------------------------------------------------------------

# --- Core ---
APP_NAME=Clippify
APP_SECRET=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:8011
APP_PORT=8011

# --- PostgreSQL 16 (system of record) ---
POSTGRES_USER=clippify
POSTGRES_PASSWORD=clippify
POSTGRES_DB=clippify
# Inside the compose network the host is the service name "db".
DATABASE_URL=postgresql+psycopg://clippify:clippify@db:5432/clippify

# --- Redis (broker + SSE ONLY — never a system of record) ---
REDIS_URL=redis://redis:6379/0

# --- FFmpeg binaries ---
# Frozen contract uses Windows absolute paths on the host shell:
#   C:\ffmpeg\bin\ffmpeg.exe  /  C:\ffmpeg\bin\ffprobe.exe
# Inside the Linux container they live on PATH; compose overrides these two.
FFMPEG_BIN=C:\ffmpeg\bin\ffmpeg.exe
FFPROBE_BIN=C:\ffmpeg\bin\ffprobe.exe

# --- Render ---
# Frozen NVENC flags are hardcoded in render/ffmpeg.py; this only toggles the
# codec family. Set to "nvenc" on a host with an NVIDIA GPU; "x264" elsewhere
# so the acceptance test still runs without a GPU.
VIDEO_CODEC=x264
ASR_MODEL=tiny
ASR_DEVICE=cpu
YUNET_MODEL_URL=https://github.com/opencv/opencv_zoo/raw/main/models/face_detection_yunet/face_detection_yunet_2023mar.onnx

# --- Seeded dev user (created by entrypoint on first boot) ---
SEED_USER_EMAIL=demo@clippify.dev
SEED_USER_PASSWORD=clippify-demo
SEED_USER_CREDITS=30

# --- DEFERRED features (left blank in the walking skeleton) ---
# Stripe — billing is a deferred seam. Leave unset: SDK stays lazy-unloaded.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# OAuth publishing — deferred seam.
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
