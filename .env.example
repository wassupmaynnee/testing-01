# ----------------------------------------------------------------------------
# Clippify SaaS — environment template.
# Copy to .env and fill values. NEVER commit a real .env.
# ----------------------------------------------------------------------------

# --- Core ---
APP_NAME=Clippify
APP_SECRET=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:8011
APP_PORT=8011
# "production" tags Sentry and disables the webhook demo-user fallback (a
# metadata-less Stripe event grants nothing in production).
APP_ENV=development

# --- PostgreSQL 16 (system of record) ---
POSTGRES_USER=clippify
POSTGRES_PASSWORD=clippify
POSTGRES_DB=clippify
# Inside the compose network the host is the service name "db".
DATABASE_URL=postgresql+psycopg://clippify:clippify@db:5432/clippify

# --- Redis (broker + SSE ONLY — never a system of record) ---
REDIS_URL=redis://redis:6379/0

# --- FFmpeg binaries ---
# Frozen contract uses Windows absolute paths on the host shell:
#   C:\ffmpeg\bin\ffmpeg.exe  /  C:\ffmpeg\bin\ffprobe.exe
# Inside the Linux container they live on PATH; compose overrides these two.
FFMPEG_BIN=C:\ffmpeg\bin\ffmpeg.exe
FFPROBE_BIN=C:\ffmpeg\bin\ffprobe.exe

# --- Render ---
# Frozen NVENC flags are hardcoded in render/ffmpeg.py; this only toggles the
# codec family. Set to "nvenc" on a host with an NVIDIA GPU; "x264" elsewhere
# so the acceptance test still runs without a GPU.
VIDEO_CODEC=x264
ASR_MODEL=tiny
ASR_DEVICE=cpu
YUNET_MODEL_URL=https://github.com/opencv/opencv_zoo/raw/main/models/face_detection_yunet/face_detection_yunet_2023mar.onnx

# --- Seeded dev user (created by entrypoint on first boot) ---
SEED_USER_EMAIL=demo@clippify.dev
SEED_USER_PASSWORD=clippify-demo
SEED_USER_CREDITS=30

# --- Stripe billing ---
# Leave both blank to run without billing (the app still boots and the pricing UI
# still renders; checkout/portal report "deferred"). Set them to go live — the
# SDK lazy-loads only when STRIPE_SECRET_KEY is present, and the webhook is
# verified with our own HMAC-SHA256 over the raw body. See STRIPE_LOCAL_TESTING.md.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: real Stripe Price IDs per paid tier. If blank, checkout builds an
# inline recurring price from the frozen catalog (works in test mode with no setup).
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
# Where Stripe returns the buyer (default: the dashboard with a ?checkout= flag).
BILLING_SUCCESS_URL=
BILLING_CANCEL_URL=

# --- Observability (Sentry). Blank DSN = monitoring disabled (no-op on boot). ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Privacy-friendly analytics (Plausible). Blank = no script injected.
# Set to your verified domain, e.g. clippify.app. Respects Do-Not-Track, no PII. ---
PLAUSIBLE_DOMAIN=

# --- OAuth publishing — deferred seam (OAuth 2.0 only, private/SELF_ONLY). ---
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# --- Deploy (used by .github/workflows/deploy.yml on the host, not the app).
# On the container host, point compose at the pushed image:
#   CLIPPIFY_IMAGE=ghcr.io/<owner>/<repo>:latest
CLIPPIFY_IMAGE=
